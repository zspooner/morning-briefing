# News API (https://newsapi.org/)
NEWS_API_KEY=your_news_api_key

# Groq API for Llama (https://console.groq.com/ - free tier available)
GROQ_API_KEY=your_groq_api_key

# Webull credentials
WEBULL_EMAIL=your_webull_email
WEBULL_PASSWORD=your_webull_password
WEBULL_DEVICE_ID=your_device_id
WEBULL_TRADE_TOKEN=your_trade_token

# ntfy topic (default: zack-briefing)
NTFY_TOPIC=zack-briefing
